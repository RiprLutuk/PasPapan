APP_NAME="PAS Papan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://paspapan.vercel.app
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_STORAGE_PATH=/tmp/storage
APP_CONFIG_CACHE=/tmp/storage/framework/cache/config.php
APP_EVENTS_CACHE=/tmp/storage/framework/cache/events.php
APP_PACKAGES_CACHE=/tmp/storage/framework/cache/packages.php
APP_ROUTES_CACHE=/tmp/storage/framework/cache/routes-v7.php
APP_SERVICES_CACHE=/tmp/storage/framework/cache/services.php
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=debug
BCRYPT_ROUNDS=12

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=/etc/ssl/cert.pem

CACHE_STORE=array
CACHE_PREFIX=
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
ANNOUNCEMENT_REFRESH_MODE=auto
ANNOUNCEMENT_POLL_INTERVAL=60s

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@paspapan.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
