{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "buildCommand": "bun run build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "env": {
        "APP_STORAGE_PATH": "/tmp/storage",
        "LOG_CHANNEL": "stderr",
        "QUEUE_CONNECTION": "sync"
    },
    "routes": [
        {
            "src": "/(build|assets|js|models|temp)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(favicon\\.ico|manifest\\.json|robots\\.txt|sw\\.js|offline\\.html|hero-banner\\.png)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
