{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "buildCommand": "bun run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4",
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "env": {
        "APP_STORAGE_PATH": "/tmp/storage",
        "LOG_CHANNEL": "stderr",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "SESSION_SECURE_COOKIE": "true",
        "QUEUE_CONNECTION": "sync",
        "MAIL_MAILER": "log",
        "BROADCAST_CONNECTION": "log",
        "ANNOUNCEMENT_REFRESH_MODE": "auto"
    },
    "routes": [
        {
            "src": "/(build|assets|images|js|models|temp)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(favicon\\.ico|manifest\\.json|robots\\.txt|sw\\.js|offline\\.html|hero-banner\\.png)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
